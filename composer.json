{
    "name": "arm092/livewire-datatables",
    "description": "Advanced datatables using Laravel, Livewire, Tailwind CSS and Alpine JS",
    "keywords": [
        "php",
        "laravel",
        "livewire",
        "datatables",
        "tall"
    ],
    "homepage": "https://github.com/arm092/livewire-datatables",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Mark Salmon",
            "email": "mark.salmon@mediconesystems.com",
            "role": "Developer"
        },
        {
            "name": "Shane Burrell",
            "email": "shane@shaneburrell.com",
            "role": "Developer"
        },
        {
            "name": "Herbert Maschke",
            "email": "thyseus@pm.me",
            "role": "Developer"
        },
        {
            "name": "Arman Khachatryan",
            "email": "arman.khachatryan@apricode.am",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1.68",
        "psr/simple-cache": "^3.0.0",
        "reedware/laravel-relation-joins": "^7.0|^8.0|^9.0"
    },
    "require-dev": {
        "cweagans/composer-patches": "^2.0",
        "laravel/legacy-factories": "^1.4.1",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "suggest": {
        "cweagans/composer-patches": "If you install this plugin in your application, patch definitions from this package may apply to reedware/laravel-relation-joins v9 (Laravel 12.55+ / 13). For Laravel 10–12 (reedware v7–v8), set extra.composer-patches.ignore-dependency-patches to [\"arm092/livewire-datatables\"] so the v9-only patch is skipped."
    },
    "autoload": {
        "psr-4": {
            "Arm092\\LivewireDatatables\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arm092\\LivewireDatatables\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "cweagans/composer-configurable-plugin": true,
            "cweagans/composer-patches": true
        }
    },
    "extra": {
        "patches": {
            "reedware/laravel-relation-joins": {
                "Macro-aware join mixin assertions (reedware v9.0.x, PHP assert + Laravel macros)": "patches/reedware-laravel-relation-joins-mixin-assertions.patch"
            }
        },
        "laravel": {
            "providers": [
                "Arm092\\LivewireDatatables\\LivewireDatatablesServiceProvider"
            ],
            "aliases": {
                "LivewireDatatables": "Arm092\\LivewireDatatables\\LivewireDatatablesFacade"
            }
        }
    },
    "prefer-stable": true
}
