diff --git a/src/JoinMixinAssertions.php b/src/JoinMixinAssertions.php
new file mode 100644
index 0000000..aa9c1e5
--- /dev/null
+++ b/src/JoinMixinAssertions.php
@@ -0,0 +1,29 @@
+<?php
+
+namespace Reedware\LaravelRelationJoins;
+
+use Illuminate\Database\Eloquent\Builder as EloquentBuilder;
+use Illuminate\Database\Query\Builder as QueryBuilder;
+
+/**
+ * @internal
+ */
+final class JoinMixinAssertions
+{
+    /**
+     * Macros registered via {@see EloquentBuilder::mixin()} / {@see QueryBuilder::mixin()}
+     * are not visible to method_exists() on the instance.
+     */
+    public static function assertBuilderCan(EloquentBuilder $builder, string $method): void
+    {
+        $query = $builder->getQuery();
+
+        assert(
+            EloquentBuilder::hasGlobalMacro($method)
+            || $builder->hasMacro($method)
+            || method_exists($builder, $method)
+            || QueryBuilder::hasMacro($method)
+            || method_exists($query, $method)
+        );
+    }
+}
